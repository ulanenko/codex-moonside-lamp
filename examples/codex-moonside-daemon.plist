<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.codex-moonside-lamp</string>
  <key>ProgramArguments</key>
  <array>
    <string>/absolute/path/to/codex-moonside-lamp/.venv/bin/codex-moonside-daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/codex-moonside-daemon.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/codex-moonside-daemon.stderr.log</string>
</dict>
</plist>
