#!/usr/bin/env bash
set -euo pipefail

LABEL="local.codex-moonside-lamp"
PLIST_PATH="$HOME/Library/LaunchAgents/$LABEL.plist"

launchctl bootout "gui/$(id -u)" "$PLIST_PATH" >/dev/null 2>&1 || true
rm -f "$PLIST_PATH"

echo "Uninstalled $LABEL"
echo "Kept config/logs under: $HOME/.codex-moonside-lamp"
echo "Remove that directory manually if you want to delete local config and logs."
